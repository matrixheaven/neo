{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neo.local/schemas/model-catalog.schema.json",
  "title": "Neo Model Catalog",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "api": {
            "type": "string",
            "minLength": 1
          },
          "capabilities": {
            "type": "object"
          },
          "pricing": {
            "type": "object"
          },
          "image_generation": {
            "type": "object"
          }
        },
        "required": [
          "provider",
          "model",
          "api",
          "capabilities"
        ]
      }
    },
    "default": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "provider",
        "model"
      ]
    },
    "providers": {
      "type": "object"
    }
  },
  "anyOf": [
    {
      "required": [
        "models"
      ]
    },
    {
      "required": [
        "providers"
      ]
    }
  ]
}
